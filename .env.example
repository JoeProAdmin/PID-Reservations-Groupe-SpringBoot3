# ============================================
# Variables d'environnement - PID Reservations
# Copier ce fichier en .env avant utilisation
# cp .env.example .env
# ============================================

# ---- Base de donnees MySQL ----
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pid_reservations_group
MYSQL_USER=pid_user
MYSQL_PASSWORD=pid_password
MYSQL_PORT=3307

# ---- Backend Spring Boot ----
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:mysql://mysql:3306/pid_reservations_group?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=pid_user
DB_PASSWORD=pid_password

# ---- Securite JWT ----
# IMPORTANT : generer une cle secrete unique en production
# Commande : openssl rand -base64 64
JWT_SECRET=CHANGER_CETTE_VALEUR_EN_PRODUCTION

# ---- Frontend React ----
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8080
